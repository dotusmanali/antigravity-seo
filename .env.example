# ==============================================================================
# Antigravity SEO & Blog Suite - Environment Configuration Template
# Copy this file to '.env' and fill in your actual API keys and credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Google Gemini & Core Cloud APIs
# ------------------------------------------------------------------------------
# Core Gemini API Key (used for outline writing, EEAT audits, text generation)
GOOGLE_AI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Google API Key (used for custom Google Search and other standard API calls)
GOOGLE_API_KEY=your_google_api_key_here

# ------------------------------------------------------------------------------
# 2. Google Analytics (GA4) & Search Console (GSC)
# ------------------------------------------------------------------------------
# Path to your Google Service Account Credentials JSON file
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-credentials.json

# GA4 Property ID (e.g., 123456789)
GA4_PROPERTY_ID=your_ga4_property_id

# Google Search Console Property site URL or Domain (e.g., sc-domain:example.com or https://example.com)
GSC_PROPERTY=https://example.com

# ------------------------------------------------------------------------------
# 3. Google Ads Keyword Planner API (for live volume, bid ranges, and CPC)
# ------------------------------------------------------------------------------
# Developer token from your Google Ads Manager Account (MCC) API Center
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token

# Google Ads OAuth2 Desktop Client Credentials
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret

# The one-time generated OAuth2 Refresh Token (AdWords scope)
GOOGLE_ADS_REFRESH_TOKEN=your_oauth_refresh_token

# Google Ads Manager Account ID (if calling managed child accounts, omit if direct access)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# ------------------------------------------------------------------------------
# 4. Third-Party SEO APIs & MCP Integrations
# ------------------------------------------------------------------------------
# DataForSEO Credentials (for live SERP analysis, domain ratings, and competitor indexes)
DATAFORSEO_USERNAME=your_dataforseo_username
DATAFORSEO_PASSWORD=your_dataforseo_password
DATAFORSEO_LOGIN=your_dataforseo_username

# Firecrawl API Key (for automated site crawler and sitemap mapping MCP server)
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key

# PageSpeed Insights API Key (optional, falls back to free public rate limits if empty)
PAGESPEED_API_KEY=your_pagespeed_api_key

# Moz API Key (optional, for authority & spam score checks)
MOZ_API_KEY=your_moz_api_key

# Bing Webmaster Tools API Key (optional)
BING_WEBMASTER_API_KEY=your_bing_webmaster_api_key

# ------------------------------------------------------------------------------
# 5. Media & Visual Asset Generation (for featured blog images)
# ------------------------------------------------------------------------------
# Unsplash API Access Key (for automatic royalty-free image extraction)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Pexels API Key
PEXELS_API_KEY=your_pexels_api_key

# Pixabay API Key
PIXABAY_API_KEY=your_pixabay_api_key

# ------------------------------------------------------------------------------
# 6. LLM Provider Fallbacks (Optional override for custom OpenAI / custom LLM)
# ------------------------------------------------------------------------------
# Set to 'openai', 'nvidia', or 'kie' to override Gemini defaults
LLM_PROVIDER=gemini
LLM_API_KEY=your_llm_api_key
LLM_MODEL=your_llm_model_name

# Specific provider keys (only needed if LLM_PROVIDER is active)
OPENAI_API_KEY=your_openai_api_key
NVIDIA_API_KEY=your_nvidia_api_key
KIE_API_KEY=your_kie_api_key

# ------------------------------------------------------------------------------
# 7. System & Debug Flags
# ------------------------------------------------------------------------------
# GitHub personal token (optional, for checking remote resources)
GITHUB_TOKEN=your_github_token

# Set to 1 to enable verbose debugging logs for browser automation scripts
BLOG_DEBUG=0
